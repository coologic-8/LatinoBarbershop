# ========================================
# Latino's Barbershop — Server Configuration
# ========================================
# Copy this file and rename to .env, then fill in your values.

# Server port
PORT=3000

# ── Owner Notification Email ──
# This is the email address that will receive booking notifications.
OWNER_EMAIL=your-email@gmail.com

# ── SMTP Configuration ──
# For Gmail: use smtp.gmail.com, port 587
# You'll need a Gmail App Password (not your regular password):
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an "App Password" for "Mail"
# 3. Paste the 16-character password below
#
# For other providers:
#   Outlook: smtp.office365.com, port 587
#   Yahoo: smtp.mail.yahoo.com, port 587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=


